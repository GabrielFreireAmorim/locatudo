# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env — ele está no .gitignore.

# -----------------------------------------------
# Supabase
# Encontre em: Dashboard → Settings → API Keys
# -----------------------------------------------
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sb_publishable_SUA_CHAVE_AQUI

# -----------------------------------------------
# Google Sign-In (opcional — pode ser definido via google-services.json)
# Use o Web Client ID do Google Cloud Console
# -----------------------------------------------
# GOOGLE_CLIENT_ID=XXXXXXXXXX-XXXXXXXXXXXX.apps.googleusercontent.com
