# =============================================================================
# SEGREDOS E CREDENCIAIS — NUNCA COMMITAR
# =============================================================================
.env
.env.*
!.env.example

# Chaves de assinatura Android
*.keystore
*.jks
*.p12

# Google Services (contém SHA-1 e client_ids do projeto)
google-services.json
GoogleService-Info.plist

# Supabase / Firebase configs locais
**/supabase/.temp/

# =============================================================================
# FLUTTER / DART / PUB
# =============================================================================
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# =============================================================================
# ANDROID
# =============================================================================
**/android/**/gradle-wrapper.jar
**/android/.gradle
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
/android/app/debug
/android/app/profile
/android/app/release

